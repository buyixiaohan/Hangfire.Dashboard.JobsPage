@* Generator: Template TypeVisibility: Internal GeneratePrettyNames: True Namespace: JobsPages4Hangfire.Dashboard.Pages *@
@using JobsPages4Hangfire.Dashboard.Pages
@using Hangfire.Dashboard.Pages
@using JobsPages4Hangfire.Dashboard.resx
@using JobsPages4Hangfire.Dashboard.Support
@inherits Hangfire.Dashboard.RazorPage

@{
    Layout = new LayoutPage(Title);  // 设置布局页
    Func<string, string> T = ManagementLocalization.Get;
}
<link rel="stylesheet" type="text/css" href="@Url.To(@UrlRoute+"/jsmcss")" />


<div class="container">
    <div class="row">
        <div class="col-md-3">

            @Html.RenderPartial(new SideBarMenu(ManagementSidebarMenu.Items))
        </div>

        <div class="col-md-9">
            <h1 class="page-header mgmt-title">@Title</h1>
            <div class="visible-md-block visible-lg-block">
                <p class="d-block">@Resource.PageDescriptionLeft</p>
            </div>
            <div class="hidden-md hidden-lg">
                <p class="d-block">@Resource.PageDescriptionTop</p>
            </div>
            <div class="management-manual mt-5">
                <h1 class="text-center text-primary mb-5">@T("Manual_Title")</h1>

                <div class="row">
                    <div class="col-md-12">
                        <h2 class="h4 font-weight-bold text-dark mb-3">1. @T("Manual_Overview_Title")</h2>
                        <p class="lead text-muted">
                            @T("Manual_Overview_Lead")
                        </p>
                        <p class="text-muted">
                            @T("Manual_Overview_Intro")
                        </p>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">@T("Manual_Action_Immediate")</li>
                            <li class="list-group-item">@T("Manual_Action_Scheduled")</li>
                            <li class="list-group-item">@T("Manual_Action_Delayed")</li>
                            <li class="list-group-item">@T("Manual_Action_Recurring")</li>
                        </ul>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-md-12">
                        <h2 class="h4 font-weight-bold text-dark mb-4">2. @T("Manual_Steps_Title")</h2>

                        <div class="card mb-4">
                            <div class="card-body">
                                <h3 class="h5 font-weight-bold text-primary">2.1 @T("Manual_Immediate_Title")</h3>
                                <p>
                                    @T("Manual_Immediate_Description")
                                </p>
                                <ul class="list-group">
                                    <li class="list-group-item">@T("Manual_Immediate_Step1")</li>
                                    <li class="list-group-item">@T("Manual_Immediate_Step2")</li>
                                </ul>
                                <p class="mt-3 text-muted"><strong>@T("Manual_Example_Label")</strong></p>
                                <figure class="management-manual-image">
                                    <img src="@Url.To($"{UrlRoute}/images/execute-now-example.png")" alt="@T("Manual_Immediate_ImageAlt")" />
                                </figure>
                            </div>
                        </div>

                        <div class="card mb-4">
                            <div class="card-body">
                                <h3 class="h5 font-weight-bold text-primary">2.2 @T("Manual_Scheduled_Title")</h3>
                                <p>
                                    @T("Manual_Scheduled_Description")
                                </p>
                                <ul class="list-group">
                                    <li class="list-group-item">@T("Manual_Scheduled_Step1")</li>
                                    <li class="list-group-item">@T("Manual_Scheduled_Step2")</li>
                                    <li class="list-group-item">@T("Manual_Scheduled_Step3")</li>
                                </ul>
                                <p class="mt-3 text-muted"><strong>@T("Manual_Example_Label")</strong></p>
                                <figure class="management-manual-image">
                                    <img src="@Url.To($"{UrlRoute}/images/schedule-job-example.png")" alt="@T("Manual_Scheduled_ImageAlt")" />
                                </figure>
                            </div>
                        </div>

                        <div class="card mb-4">
                            <div class="card-body">
                                <h3 class="h5 font-weight-bold text-primary">2.3 @T("Manual_Delayed_Title")</h3>
                                <p>
                                    @T("Manual_Delayed_Description")
                                </p>
                                <ul class="list-group">
                                    <li class="list-group-item">@T("Manual_Delayed_Step1")</li>
                                    <li class="list-group-item">@T("Manual_Delayed_Step2")</li>
                                    <li class="list-group-item">@T("Manual_Delayed_Step3")</li>
                                </ul>
                                <p class="mt-3 text-muted"><strong>@T("Manual_Example_Label")</strong></p>
                                <figure class="management-manual-image">
                                    <img src="@Url.To($"{UrlRoute}/images/delayed-job-example.png")" alt="@T("Manual_Delayed_ImageAlt")" />
                                </figure>
                            </div>
                        </div>

                        <div class="card mb-4">
                            <div class="card-body">
                                <h3 class="h5 font-weight-bold text-primary">2.4 @T("Manual_Recurring_Title")</h3>
                                <p>
                                    @T("Manual_Recurring_Description")
                                </p>
                                <ul class="list-group">
                                    <li class="list-group-item">@T("Manual_Recurring_Step1")</li>
                                    <li class="list-group-item">@T("Manual_Recurring_Step2")</li>
                                    <li class="list-group-item">@T("Manual_Recurring_Step3")</li>
                                </ul>
                                <p class="mt-3 text-muted"><strong>@T("Manual_Example_Label")</strong></p>
                                <figure class="management-manual-image">
                                    <img src="@Url.To($"{UrlRoute}/images/recurring-job-example.png")" alt="@T("Manual_Recurring_ImageAlt")" />
                                </figure>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-md-12">
                        <h2 class="h4 font-weight-bold text-dark mb-4">3. @T("Manual_Faq_Title")</h2>

                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="h6 font-weight-bold text-dark">@T("Manual_Faq_Status_Q")</h5>
                                <p>@T("Manual_Faq_Status_A")</p>
                            </div>
                        </div>

                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="h6 font-weight-bold text-dark">@T("Manual_Faq_Failure_Q")</h5>
                                <p>@T("Manual_Faq_Failure_A")</p>
                            </div>
                        </div>

                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="h6 font-weight-bold text-dark">@T("Manual_Faq_UpdateSchedule_Q")</h5>
                                <p>@T("Manual_Faq_UpdateSchedule_A")</p>
                            </div>
                        </div>

                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="h6 font-weight-bold text-dark">@T("Manual_Faq_Delay_Q")</h5>
                                <p>@T("Manual_Faq_Delay_A")</p>
                            </div>
                        </div>

                        <div class="card mb-4">
                            <div class="card-body">
                                <h5 class="h6 font-weight-bold text-dark">@T("Manual_Faq_Delete_Q")</h5>
                                <p>@T("Manual_Faq_Delete_A")</p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>


    </div>
</div>
